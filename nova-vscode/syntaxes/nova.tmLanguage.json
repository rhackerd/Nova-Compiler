{
    "name": "Nova",
    "scopeName": "source.nova",
    "fileTypes": ["nl", "nh"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#function-def" },
        { "include": "#function-call" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#punctuation" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.nova",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.nova",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.nova",
                            "match": "\\\\[nrt\"\\\\0]"
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.nova",
                    "match": "\\b(ret|if|else|while|for|break|continue)\\b"
                },
                {
                    "name": "keyword.declaration.nova",
                    "match": "\\b(func|let|mut|ext)\\b"
                },
                {
                    "name": "keyword.other.nova",
                    "match": "\\b(extern|inline|static)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "storage.type.nova",
                    "match": "\\b(u8|u16|u32|u64|i8|i16|i32|i64|f32|f64|bool|void)\\b"
                }
            ]
        },
        "function-def": {
            "patterns": [
                {
                    "comment": "function definition: func name(",
                    "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "keyword.declaration.nova" },
                        "2": { "name": "entity.name.function.nova" }
                    }
                },
                {
                    "comment": "ext function declaration: ext func name(",
                    "match": "\\b(ext)\\s+(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "keyword.declaration.nova" },
                        "2": { "name": "keyword.declaration.nova" },
                        "3": { "name": "entity.name.function.nova" }
                    }
                }
            ]
        },
        "function-call": {
            "patterns": [
                {
                    "comment": "function call: name(",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": { "name": "entity.name.function.call.nova" }
                    }
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.nova",
                    "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.hex.nova",
                    "match": "\\b0x[0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.integer.nova",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.nova",
                    "match": "->"
                },
                {
                    "name": "keyword.operator.arithmetic.nova",
                    "match": "[+\\-*/]"
                },
                {
                    "name": "keyword.operator.comparison.nova",
                    "match": "(==|!=|<=|>=|<|>)"
                },
                {
                    "name": "keyword.operator.assignment.nova",
                    "match": "(?<![=!<>])=(?!=)"
                },
                {
                    "name": "keyword.operator.logical.nova",
                    "match": "(&&|\\|\\||!)"
                }
            ]
        },
        "punctuation": {
            "patterns": [
                {
                    "name": "punctuation.terminator.nova",
                    "match": ";"
                },
                {
                    "name": "punctuation.separator.nova",
                    "match": ","
                },
                {
                    "name": "punctuation.separator.colon.nova",
                    "match": ":"
                },
                {
                    "name": "punctuation.section.braces.nova",
                    "match": "[{}]"
                },
                {
                    "name": "punctuation.section.parens.nova",
                    "match": "[()]"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.nova",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}
